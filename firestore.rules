rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // ============================================
    // FUNCIONES AUXILIARES
    // ============================================
    
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(organizadorId) {
      return isAuthenticated() && request.auth.uid == organizadorId;
    }
    
    function isValidString(value, minLength, maxLength) {
      return value is string 
        && value.size() >= minLength 
        && value.size() <= maxLength;
    }
    
    // ✅ NUEVA FUNCIÓN: Validar estructura de expositor
    function isValidExpositor(expositor) {
      return expositor is map
        && expositor.keys().hasAll(['nombre', 'correo', 'hora', 'tema'])
        && expositor.nombre is string
        && expositor.nombre.size() >= 2
        && expositor.nombre.size() <= 200
        && expositor.correo is string
        && expositor.correo.size() >= 5
        && expositor.correo.size() <= 200
        && expositor.correo.matches('.*@.*\\..*')
        && expositor.hora is string
        && expositor.hora.size() >= 4
        && expositor.hora.size() <= 5
        && expositor.tema is string
        && expositor.tema.size() >= 3
        && expositor.tema.size() <= 300;
    }
    
    // ✅ NUEVA FUNCIÓN: Validar array de expositores
    function isValidExpositoresArray(expositores) {
      return expositores is list
        && expositores.size() >= 1
        && expositores.size() <= 20;
    }
    
    // ✅ NUEVA FUNCIÓN: Validar estructura de QR individual
    function isValidQRData(qrData) {
      return qrData is map
        && qrData.keys().hasAll(['qrString', 'qrId', 'token', 'fechaDia', 'generadoEn', 'usado'])
        && qrData.qrString is string
        && qrData.qrString.size() >= 10
        && qrData.qrString.size() <= 5000
        && qrData.qrId is string
        && qrData.qrId.size() >= 10
        && qrData.qrId.size() <= 200
        && qrData.token is string
        && qrData.token.size() == 64  // SHA256 hash
        && qrData.fechaDia is string
        && qrData.fechaDia.size() == 10  // Formato YYYY-MM-DD
        && qrData.fechaDia.matches('\\d{4}-\\d{2}-\\d{2}')
        && qrData.generadoEn is string
        && qrData.usado is bool;
    }
    
    // ✅ NUEVA FUNCIÓN: Validar objeto qrsPorDia (QRs por día)
    function isValidQRsPorDia(qrsPorDia) {
      return qrsPorDia is map
        && qrsPorDia.size() >= 1
        && qrsPorDia.size() <= 365;  // Máximo 365 días de evento
    }
    
    // ✅ NUEVA FUNCIÓN: Validar estructura de participante (nuevo formato)
    function isValidParticipanteInfo(participante) {
      return participante is map
        && participante.keys().hasAll(['id', 'email', 'fechaInscripcion', 'estado'])
        && participante.id is string
        && participante.email is string
        && participante.email.matches('.*@.*\\..*')
        && participante.fechaInscripcion is string
        && participante.estado in ['inscrito', 'cancelado', 'asistio']
        // Validar qrsPorDia si existe (nuevo formato)
        && (!participante.keys().hasAny(['qrsPorDia']) 
            || isValidQRsPorDia(participante.qrsPorDia))
        // Permitir qrData para compatibilidad con formato antiguo
        && (!participante.keys().hasAny(['qrData']) 
            || participante.qrData is map);
    }
    
    // ============================================
    // REGLAS PARA USUARIOS
    // ============================================
    
    match /users/{userId} {
      // Los usuarios pueden leer su propio documento
      allow read: if isAuthenticated() && request.auth.uid == userId;
      
      // Los usuarios pueden crear su propio documento al registrarse
      allow create: if isAuthenticated() 
        && request.auth.uid == userId
        && request.resource.data.keys().hasAll(['uid', 'nombre', 'apellido', 'email', 'role'])
        && request.resource.data.uid == userId
        && request.resource.data.email == request.auth.token.email
        && isValidString(request.resource.data.nombre, 2, 100)
        && isValidString(request.resource.data.apellido, 2, 100)
        && request.resource.data.role in ['alumno', 'organizador'];
      
      // ✅ ACTUALIZADO: Los usuarios pueden actualizar solo nombre y apellido
      allow update: if isAuthenticated() 
        && request.auth.uid == userId
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['nombre', 'apellido'])
        && isValidString(request.resource.data.nombre, 2, 100)
        && isValidString(request.resource.data.apellido, 2, 100)
        // No se puede cambiar el email ni el role
        && request.resource.data.email == resource.data.email
        && request.resource.data.role == resource.data.role
        && request.resource.data.uid == resource.data.uid;
    }
    
    // ============================================
    // REGLAS PARA EVENTOS
    // ============================================
    
    match /eventos/{eventoId} {
      
      // -------------------------------------------
      // LECTURA DE EVENTOS
      // -------------------------------------------
      
      // Permitir lectura pública de eventos publicados
      allow read: if isAuthenticated() && resource.data.estado == 'publicado';
      
      // Permitir lectura completa solo al organizador del evento (por UID)
      allow read: if isOwner(resource.data.organizadorId);
      
      // ✅ NUEVO: Permitir lectura por email del organizador (para reportes)
      allow read: if isAuthenticated() 
        && resource.data.organizador == request.auth.token.email;
      
      // -------------------------------------------
      // CREACIÓN DE EVENTOS
      // -------------------------------------------
      
      allow create: if isAuthenticated() 
        && request.auth.uid == request.resource.data.organizadorId
        // Validar que tenga todos los campos requeridos (nuevo modelo O modelo antiguo para compatibilidad)
        && (
          // NUEVO MODELO: Soporte para fechaInicio/fechaFin/horaInicio/horaFin/expositores
          (request.resource.data.keys().hasAll([
            'titulo', 'descripcion', 'fechaInicio', 'fechaFin', 'horaInicio', 'horaFin',
            'ubicacion', 'capacidadMaxima', 'tipo', 'estado', 'organizadorId', 'expositores'
          ]) &&
          request.resource.data.fechaInicio is string &&
          request.resource.data.fechaFin is string &&
          request.resource.data.horaInicio is string &&
          request.resource.data.horaFin is string &&
          isValidExpositoresArray(request.resource.data.expositores))
          ||
          // MODELO ANTIGUO: Soporte para fecha/hora/expositor (compatibilidad retroactiva)
          (request.resource.data.keys().hasAll([
            'titulo', 'descripcion', 'fecha', 'hora', 
            'ubicacion', 'capacidadMaxima', 'tipo', 'estado', 'organizadorId'
          ]) &&
          request.resource.data.fecha is string &&
          request.resource.data.hora is string)
        )
        // Validar tipos de datos y rangos (campos comunes)
        && request.resource.data.organizadorId is string
        && isValidString(request.resource.data.titulo, 10, 100)
        && isValidString(request.resource.data.descripcion, 20, 500)
        && isValidString(request.resource.data.ubicacion, 3, 200)
        && request.resource.data.capacidadMaxima is int
        && request.resource.data.capacidadMaxima >= 1
        && request.resource.data.capacidadMaxima <= 1000
        && request.resource.data.tipo in ['conferencia', 'seminario', 'taller', 'curso', 'charla']
        && request.resource.data.estado in ['borrador', 'publicado']
        // Validar campo expositor (opcional - modelo antiguo)
        && (!request.resource.data.keys().hasAny(['expositor']) 
            || (request.resource.data.expositor is string && request.resource.data.expositor.size() <= 200))
        // Validar campo expositorEmail (opcional - modelo antiguo)
        && (!request.resource.data.keys().hasAny(['expositorEmail']) 
            || (request.resource.data.expositorEmail is string 
                && request.resource.data.expositorEmail.size() >= 5
                && request.resource.data.expositorEmail.size() <= 200
                && request.resource.data.expositorEmail.matches('.*@.*\\..*')))
        // Validar arrays de participantes (deben iniciar vacíos o no existir)
        && (!request.resource.data.keys().hasAny(['participantes']) 
            || request.resource.data.participantes.size() == 0)
        && (!request.resource.data.keys().hasAny(['participantesInfo']) 
            || request.resource.data.participantesInfo.size() == 0)
        // ✅ OPTIMIZADO: Sin validación de 'asistentes' o 'asistenciaQR' (ya no se usan)
        && (!request.resource.data.keys().hasAny(['asistenciasPorDia']) 
            || request.resource.data.asistenciasPorDia is map);
      
      // -------------------------------------------
      // ACTUALIZACIÓN DE EVENTOS
      // -------------------------------------------
      
      allow update: if isAuthenticated() && (
        // CASO 1: El organizador actualiza su evento (por UID)
        (isOwner(resource.data.organizadorId) &&
         isOwner(request.resource.data.organizadorId) &&
         // Validaciones de campos editables (comunes)
         isValidString(request.resource.data.titulo, 10, 100) &&
         isValidString(request.resource.data.descripcion, 20, 500) &&
         request.resource.data.capacidadMaxima >= 1 &&
         request.resource.data.capacidadMaxima <= 1000 &&
         request.resource.data.tipo in ['conferencia', 'seminario', 'taller', 'curso', 'charla'] &&
         request.resource.data.estado in ['borrador', 'publicado'] &&
         // Validaciones modelo antiguo (opcional)
         (!request.resource.data.keys().hasAny(['expositor']) 
             || (request.resource.data.expositor is string && request.resource.data.expositor.size() <= 200)) &&
         (!request.resource.data.keys().hasAny(['expositorEmail']) 
             || (request.resource.data.expositorEmail is string 
                 && request.resource.data.expositorEmail.size() >= 5
                 && request.resource.data.expositorEmail.size() <= 200
                 && request.resource.data.expositorEmail.matches('.*@.*\\..*'))) &&
         // Validaciones modelo nuevo (si existen estos campos)
         (!request.resource.data.keys().hasAny(['expositores']) 
             || isValidExpositoresArray(request.resource.data.expositores)) &&
         (!request.resource.data.keys().hasAny(['fechaInicio']) 
             || request.resource.data.fechaInicio is string) &&
         (!request.resource.data.keys().hasAny(['fechaFin']) 
             || request.resource.data.fechaFin is string) &&
         (!request.resource.data.keys().hasAny(['horaInicio']) 
             || request.resource.data.horaInicio is string) &&
         (!request.resource.data.keys().hasAny(['horaFin']) 
             || request.resource.data.horaFin is string)) ||
        
        // CASO 1B: El organizador actualiza su evento (por email - para mantenimiento automático)
        (resource.data.organizador == request.auth.token.email &&
         request.resource.data.organizador == request.auth.token.email) ||
        
        // ✅ NUEVO CASO 1C: Organizador cierra inscripciones manualmente
        (request.auth.uid == resource.data.organizadorId &&
         request.resource.data.diff(resource.data).affectedKeys().hasOnly(['inscripcionesAbiertas', 'fechaCierre']) &&
         request.resource.data.inscripcionesAbiertas == false) ||
        
        // CASO 2: Operaciones de inscripción/desinscripción de participantes
        (isValidParticipantOperation() && onlyUpdatingParticipantFields())
      );
      
      // -------------------------------------------
      // ELIMINACIÓN DE EVENTOS
      // -------------------------------------------
      
      allow delete: if isOwner(resource.data.organizadorId)
        || (isAuthenticated() && resource.data.organizador == request.auth.token.email);
    }
    
    // ============================================
    // COLECCIÓN: INSCRIPCIONES (OPCIONAL - Para uso futuro)
    // ============================================
    
    match /inscripciones/{inscripcionId} {
      // Los usuarios pueden ver sus propias inscripciones
      allow read: if isAuthenticated() && request.auth.uid == resource.data.userId;
      
      // Los organizadores pueden ver las inscripciones de sus eventos
      allow read: if isAuthenticated() 
        && exists(/databases/$(database)/documents/eventos/$(resource.data.eventId))
        && get(/databases/$(database)/documents/eventos/$(resource.data.eventId)).data.organizadorId == request.auth.uid;
      
      // Los usuarios pueden crear sus propias inscripciones
      allow create: if isAuthenticated() 
        && request.auth.uid == request.resource.data.userId
        && request.resource.data.eventId is string
        && request.resource.data.userId is string
        && request.resource.data.email is string
        && request.resource.data.estado is string;
      
      // Los usuarios pueden cancelar sus propias inscripciones
      allow delete: if isAuthenticated() && request.auth.uid == resource.data.userId;
      
      // Los usuarios pueden actualizar sus propias inscripciones
      allow update: if isAuthenticated() && request.auth.uid == resource.data.userId;
      
      // Los organizadores pueden gestionar inscripciones de sus eventos
      allow update, delete: if isAuthenticated() 
        && exists(/databases/$(database)/documents/eventos/$(resource.data.eventId))
        && get(/databases/$(database)/documents/eventos/$(resource.data.eventId)).data.organizadorId == request.auth.uid;
    }
    
    // ============================================
    // FUNCIONES AUXILIARES PARA PARTICIPANTES
    // ============================================
    
    function onlyUpdatingParticipantFields() {
      // Permitir actualización de campos relacionados con participantes Y sistema QR
      // ✅ OPTIMIZADO: Eliminados 'asistentes' y 'asistenciaQR' (redundantes)
      let affectedKeys = request.resource.data.diff(resource.data).affectedKeys();
      return affectedKeys.hasOnly(['participantes', 'participantesInfo', 'asistenciasPorDia', 'qrUsados', 'fechaActualizacion']);
    }
    
    function isValidParticipantOperation() {
      let currentParticipants = resource.data.get('participantes', []);
      let newParticipants = request.resource.data.get('participantes', []);
      let currentUserId = request.auth.uid;
      
      return (
        // CASO 1: Usuario se inscribe (se agrega a la lista)
        (newParticipants.size() == currentParticipants.size() + 1 &&
         newParticipants.hasAll(currentParticipants) &&
         currentUserId in newParticipants &&
         !(currentUserId in currentParticipants) &&
         isValidInscription() &&
         // Validar que no exceda la capacidad
         newParticipants.size() <= resource.data.capacidadMaxima) ||
        
        // CASO 2: Usuario se desinscribe (se remueve de la lista)
        (currentParticipants.size() == newParticipants.size() + 1 &&
         currentParticipants.hasAll(newParticipants) &&
         currentUserId in currentParticipants &&
         !(currentUserId in newParticipants) &&
         isValidDesinscription()) ||
        
        // CASO 3: Organizador marca asistencia (actualiza asistentes)
        (request.auth.uid == resource.data.organizadorId &&
         request.resource.data.participantes == resource.data.participantes &&
         isValidAttendanceUpdate()) ||
        
        // CASO 4: Sistema QR registra asistencia (via organizador)
        (request.auth.uid == resource.data.organizadorId &&
         request.resource.data.participantes == resource.data.participantes &&
         request.resource.data.get('participantesInfo', []).size() == resource.data.get('participantesInfo', []).size() &&
         isValidQRAttendanceUpdate()) ||
        
        // ✅ NUEVO CASO 5: Organizador elimina participante
        (request.auth.uid == resource.data.organizadorId &&
         isValidParticipantRemoval())
      );
    }
    
    function isValidInscription() {
      let newParticipantesInfo = request.resource.data.get('participantesInfo', []);
      let currentParticipantesInfo = resource.data.get('participantesInfo', []);
      
      // Verificar que se agregó correctamente la info del participante
      // ✅ ACTUALIZADO: Validar estructura de participante (incluyendo qrsPorDia)
      // ✅ NUEVO: Validar que las inscripciones estén abiertas
      return newParticipantesInfo.size() == currentParticipantesInfo.size() + 1 &&
             newParticipantesInfo.hasAll(currentParticipantesInfo) &&
             resource.data.get('inscripcionesAbiertas', true) == true;
    }
    
    function isValidDesinscription() {
      let newParticipantesInfo = request.resource.data.get('participantesInfo', []);
      let currentParticipantesInfo = resource.data.get('participantesInfo', []);
      
      // Verificar que se removió correctamente la info del participante
      return currentParticipantesInfo.size() == newParticipantesInfo.size() + 1 &&
             currentParticipantesInfo.hasAll(newParticipantesInfo);
    }
    
    function isValidAttendanceUpdate() {
      let currentAsistentes = resource.data.get('asistentes', []);
      let newAsistentes = request.resource.data.get('asistentes', []);
      let currentParticipants = resource.data.get('participantes', []);
      let affectedKeys = request.resource.data.diff(resource.data).affectedKeys();
      
      // Solo se pueden agregar asistentes, no remover
      // Y solo pueden ser participantes ya inscritos
      // Permitir actualización de participantesInfo si se marca asistencia
      return newAsistentes.hasAll(currentAsistentes) &&
             newAsistentes.hasOnly(currentParticipants) &&
             (affectedKeys.hasOnly(['asistentes', 'participantesInfo']) ||
              affectedKeys.hasOnly(['asistentes']));
    }
    
    function isValidQRAttendanceUpdate() {
      let currentParticipants = resource.data.get('participantes', []);
      let affectedKeys = request.resource.data.diff(resource.data).affectedKeys();
      let newAsistenciasPorDia = request.resource.data.get('asistenciasPorDia', {});
      
      // ✅ ACTUALIZADO: Validar estructura de asistenciasPorDia
      // - Cada clave debe ser una fecha en formato YYYY-MM-DD
      // - Cada valor debe ser un map con 'asistentes' (array) y opcionalmente 'participantesInfo' (array)
      // Permitir actualización de:
      // 1. asistenciasPorDia (único campo de asistencias)
      // 2. participantesInfo (opcional, para información adicional)
      // 3. qrUsados (para tracking de QRs utilizados)
      return (affectedKeys.hasOnly(['asistenciasPorDia', 'participantesInfo', 'qrUsados']) ||
             affectedKeys.hasOnly(['asistenciasPorDia', 'qrUsados']) ||
             affectedKeys.hasOnly(['asistenciasPorDia', 'participantesInfo']) ||
             affectedKeys.hasOnly(['asistenciasPorDia'])) &&
             newAsistenciasPorDia is map;
    }
    
    // ✅ NUEVA FUNCIÓN: Validar eliminación de participante por organizador
    function isValidParticipantRemoval() {
      let currentParticipants = resource.data.get('participantes', []);
      let newParticipants = request.resource.data.get('participantes', []);
      let currentParticipantesInfo = resource.data.get('participantesInfo', []);
      let newParticipantesInfo = request.resource.data.get('participantesInfo', []);
      let currentAsistentes = resource.data.get('asistentes', []);
      let newAsistentes = request.resource.data.get('asistentes', []);
      
      // Validar que:
      // 1. Se eliminó exactamente 1 participante
      // 2. Todos los participantes nuevos estaban en la lista anterior
      // 3. Se eliminó la info correspondiente de participantesInfo
      // 4. Si el participante estaba en asistentes, también se eliminó de ahí
      // 5. La cantidad de participantesInfo se redujo en 1
      return currentParticipants.size() == newParticipants.size() + 1 &&
             currentParticipants.hasAll(newParticipants) &&
             currentParticipantesInfo.size() == newParticipantesInfo.size() + 1 &&
             // Los asistentes solo pueden reducirse, no aumentar
             newAsistentes.size() <= currentAsistentes.size() &&
             // Los nuevos asistentes deben estar en la lista actual de asistentes
             currentAsistentes.hasAll(newAsistentes);
    }
  }
}